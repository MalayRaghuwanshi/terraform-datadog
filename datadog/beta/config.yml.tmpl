# =============================================================================
# BETA CHANNEL — DATADOG MONITORING CONFIGURATION
# =============================================================================
# Same structure as alpha/config.yml.tmpl — synthetics first, then monitors.
# See the alpha config for detailed field-by-field explanations.
# =============================================================================


# =============================================================================
# SECTION A: SYNTHETIC TESTS
# =============================================================================

synthetics:

  # ---------------------------------------------------------------------------
  # SYNTHETIC 1: Beta Inventory API Health Check
  # ---------------------------------------------------------------------------
  # Standard health check — no secrets needed, public endpoint.
  # Verifies the inventory API is up and responding from us-east-1.
  # ---------------------------------------------------------------------------
  beta_inventory_api_health:

    name: "Beta Inventory API — Health Check"
    url: "https://api.acme-demo.com/inventory/health"
    method: GET
    timeout: 30
    frequency: 300
    min_failure_duration: 0
    min_location_failed: 1

    options:
      tick_every: 300
      scheduling_strategy: "round-robin"
      ignore_server_certificate_error: false

    monitor_priority: 3

    locations:
      - "aws:us-east-1"

    expected_status_code: 200

    assertions:
      - type: statusCode
        operator: is
        target: 200
      - type: responseTime
        operator: lessThan
        target: 3000

    message: |
      {{#is_alert}}
      Beta Inventory API health check failing from us-east-1.
      {{/is_alert}}
      {{#is_recovery}}
      Beta Inventory API health check recovered.
      {{/is_recovery}}
      @slack-beta-monitoring


# =============================================================================
# SECTION B: MONITORS
# =============================================================================

monitors:

  # ---------------------------------------------------------------------------
  # MONITOR 1: Beta Inventory Processing Error Rate
  # ---------------------------------------------------------------------------
  # MIGRATED FROM LEGACY APM DETECTOR:
  #   Legacy: "Beta Inventory Processing Errors"
  #   Alert when error rate on the inventory processing service exceeds 3%
  #   over the last 5 minutes.
  #
  # Lower threshold than alpha (3% vs 5%) because inventory processing errors
  # directly impact stock accuracy — even a small error rate
  # can affect many customers.
  # ---------------------------------------------------------------------------
  beta_inventory_processing_error_rate:

    name: "Beta — Inventory Processing Error Rate"
    type: "metric alert"

    query: "avg(last_5m):sum:trace.servlet.request.errors{service:beta-inventory,env:production}.as_rate() / sum:trace.servlet.request.hits{service:beta-inventory,env:production}.as_rate() * 100 > 3"

    monitor_thresholds:
      critical: 3
      critical_recovery: 1
      warning: 2

    require_full_window: false
    notify_no_data: true
    no_data_timeframe: 10
    renotify_interval: 30
    priority: 2

    message: |
      {{#is_alert}}
      Beta Inventory Processing Error Rate Alert — Error rate is {{value}}% (threshold: {{threshold}}%)
      Service: beta-inventory | Environment: production
      Impact: Stock levels and availability data may be affected.
      {{/is_alert}}
      {{#is_warning}}
      Beta Inventory Processing Error Rate Warning — Error rate is {{value}}%
      {{/is_warning}}
      {{#is_recovery}}
      Beta Inventory processing error rate has recovered. Current rate: {{value}}%
      {{/is_recovery}}
      @pagerduty-BETA_P2

    tags:
      - "env:production"
      - "team:beta"
      - "service:beta-inventory"
      - "migrated-from:legacy-apm"
